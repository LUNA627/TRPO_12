<Page x:Class="EF_Core.UserGroupsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:EF_Core"
      mc:Ignorable="d" 
      Background="White"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="UserGroupsPage">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Группы пользователя" 
                   FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>

        <ListView Grid.Row="1" x:Name="lvGroups" Margin="0,0,0,15"
                  Style="{StaticResource UserListView}">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Vertical">
                        <TextBlock Text="{Binding InterestGroup.Title, StringFormat='Группа: {0}'}" 
                                   FontWeight="Bold" Style="{StaticResource LabelBlock}"/>
                        <TextBlock Text="{Binding InterestGroup.Description, StringFormat='Описание: {0}'}" 
                                   Style="{StaticResource LabelBlock}"/>
                        <TextBlock Text="{Binding JoinedAt, StringFormat='Дата вступления: {0:dd.MM.yyyy}'}" 
                                   Style="{StaticResource LabelBlock}"/>
                        <TextBlock>
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource LabelBlock}">
                                    <Setter Property="Text" Value="Модератор"/>
                                    <Setter Property="Foreground" Value="Green"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsModerator}" Value="False">
                                            <Setter Property="Text" Value="Участник"/>
                                            <Setter Property="Foreground" Value="Black"/>
                                            <Setter Property="FontWeight" Value="Normal"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <Separator/>
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Назад" Width="100" Style="{StaticResource PrimaryButton}" 
                    Click="btnBack_Click"/>
        </StackPanel>
    </Grid>
</Page>
