<Window x:Class="EF_Core.GroupDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EF_Core"
        mc:Ignorable="d"
        Title="GroupDetailWindow" Height="450" Width="800">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Информация о группе" 
                   FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1" Margin="0,5">
            <TextBlock Text="Название:" FontWeight="Bold"/>
            <TextBlock x:Name="txtTitle" FontSize="16" Margin="0,5,0,15"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,5">
            <TextBlock Text="Описание:" FontWeight="Bold"/>
            <TextBlock x:Name="txtDescription" TextWrapping="Wrap" 
                       FontSize="14" Margin="0,5,0,15"/>
        </StackPanel>


        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button Content="Добавить"  Style="{StaticResource PrimaryButton}" 
                    Click="btnAddMember_Click"/>
            <Button Content="Закрыть"  Style="{StaticResource PrimaryButton}" 
                    Click="btnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>
