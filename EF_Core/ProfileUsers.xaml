<Page x:Class="EF_Core.ProfileUsers"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:EF_Core"
      mc:Ignorable="d" 
      xmlns:validators="clr-namespace:EF_Core.Validation"
      Background="White"
      d:DesignHeight="650" d:DesignWidth="800"
      Title="ProfileUsers">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="ID:" FontWeight="Bold" Style="{StaticResource LabelBlock}"/>
        <TextBlock Grid.Row="1" Text="{Binding Id}" Style="{StaticResource LabelBlock}"/>

        <Border Grid.Row="2" BorderBrush="LightGray" BorderThickness="1" CornerRadius="4" Width="120" Height="120" HorizontalAlignment="Left">
            <Image Source="{Binding Profile.AvatarUrl}"
                   Stretch="UniformToFill"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center"
                   ToolTip="{Binding Profile.AvatarUrl}"/>
        </Border>

        <TextBlock Grid.Row="3" Text="Номер телефона:" Style="{StaticResource LabelBlock}"/>
        <TextBlock Grid.Row="4" Text="{Binding Profile.PhoneNumber, StringFormat='{}{0}'}" FontWeight="Bold" Style="{StaticResource LabelBlock}"/>

        <TextBlock Grid.Row="5" Text="Дата рождения:" Style="{StaticResource LabelBlock}"/>
        <TextBlock Grid.Row="6" Text="{Binding Profile.BirthDate, StringFormat='{}{0:dd.MM.yyyy}'}" FontWeight="Bold" Style="{StaticResource LabelBlock}"/>

        <TextBlock Grid.Row="7" Text="Роль:" Style="{StaticResource LabelBlock}"/>
        <TextBlock Grid.Row="8" Text="{Binding Role.Title}" FontWeight="Bold" Style="{StaticResource LabelBlock}"/>

        <TextBlock Grid.Row="9" Text="Биография:" Style="{StaticResource LabelBlock}"/>
        <TextBlock Grid.Row="10" Text="{Binding Profile.Bio}" FontWeight="Bold" Style="{StaticResource LabelBlock}"/>

        <StackPanel Grid.Row="15" Orientation="Horizontal" HorizontalAlignment="Right" >
            
            <Button Content="Группы" Style="{StaticResource PrimaryButton}" Click="ListGroupClick" />
            <Button Content="Изменить" Style="{StaticResource PrimaryButton}" Click="OnSaveClick" />
            
            <Button Content="Назад" Style="{StaticResource PrimaryButton}" Click="OnCancelClick"  />
            

        </StackPanel>
    </Grid>
</Page>