<Page x:Class="EF_Core.MasterPage" Style="{StaticResource DefaultPage}"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:EF_Core"
      xmlns:validators="clr-namespace:EF_Core.Validation"
      mc:Ignorable="d" 
      Background="White"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="MasterPage">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal">
            <Button Content="Добавить" Click="OnAddClick" Style="{StaticResource PrimaryButton}"/>
            <Button Content="Изменить" Click="OnUpdateClick" Style="{StaticResource PrimaryButton}"/>
            <Button Content="Роли" Click="LookRolesClick" Style="{StaticResource PrimaryButton}"/>
        </StackPanel>

        <ListView Grid.Row="1" ItemsSource="{Binding Service.Users}" MouseDoubleClick="ListView_MouseDoubleClick" SelectedItem="{Binding SelectedUser}" Style="{StaticResource UserListView}">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Vertical">
                        <TextBlock Text="{Binding Id, StringFormat='Id: {0}'}" FontWeight="Bold" Style="{StaticResource LabelBlock}"/>
                        <TextBlock Text="{Binding Login, StringFormat='Login: {0}'}" Style="{StaticResource LabelBlock}"/>
                        <TextBlock Text="{Binding Name, StringFormat='Имя: {0}'}" Style="{StaticResource LabelBlock}"/>
                        <TextBlock Text="{Binding Email, StringFormat='Email: {0}'}" Style="{StaticResource LabelBlock}"/>
                        <TextBlock Text="{Binding Password, StringFormat='Пароль: {0}'}" Style="{StaticResource LabelBlock}"/>
                        <TextBlock Text="{Binding CreatedAt, StringFormat='Дата создания: {0:dd.MM.yyyy HH:mm}'}" Style="{StaticResource LabelBlock}"/>
                        <TextBlock Text="{Binding Role.Title, StringFormat='Роль: {0}'}" Style="{StaticResource LabelBlock}"/>
                        <Separator/>
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
