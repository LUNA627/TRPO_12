<Page x:Class="EF_Core.GroopPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:EF_Core"
      Background="White"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="GroopPage">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Column="0" Grid.Row="0" Orientation="Vertical" Margin="10">
            <Button Content="Добавить группу" Style="{StaticResource PrimaryButton}" 
                    Click="BtnAddGroop_Click"/>
            <Button Content="Редактировать группу" Style="{StaticResource PrimaryButton}" 
                    Click="BtnChangeGroup_Click" />
            <Button Content="Удалить группу" Style="{StaticResource PrimaryButton}" 
                    Click="BtnRemoveGroup_Click" />
            <Button Content="Добавить участника" Style="{StaticResource PrimaryButton}" 
                    Click="BtnAddMember_Click" />
            <Button Content="Назад" Style="{StaticResource PrimaryButton}" 
        Click="BtnBack_Click" />
        </StackPanel>

        <ListView Grid.Column="0" Grid.Row="1" Margin="10"
                  ItemsSource="{Binding Groups}"
                  SelectionChanged="lvGroups_SelectionChanged"
                  SelectedItem="{Binding SelectedGroup, Mode=TwoWay}"
                  Style="{StaticResource UserListView}">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Vertical">
                        <TextBlock Text="{Binding Id, StringFormat='Id: {0}'}" FontWeight="Bold" Style="{StaticResource LabelBlock}"/>
                        <TextBlock Text="{Binding Title, StringFormat='Название: {0}'}" Style="{StaticResource LabelBlock}"/>
                        <TextBlock Text="{Binding Description, StringFormat='Описание: {0}'}" Style="{StaticResource LabelBlock}"/>
                        <Separator/>
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <ListView Grid.Column="1" Grid.Row="0" Grid.RowSpan="2" Margin="10"
                  ItemsSource="{Binding Members}"
                  MouseDoubleClick="lvMembers_MouseDoubleClick"
                  SelectedItem="{Binding SelectedMember, Mode=TwoWay}"
                  Style="{StaticResource UserListView}">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Vertical">
                        <TextBlock Text="{Binding UserId, StringFormat='ID пользователя: {0}'}" FontWeight="Bold" Style="{StaticResource LabelBlock}"/>
                        <TextBlock Text="{Binding InterestGroupId, StringFormat='ID группы: {0}'}" Style="{StaticResource LabelBlock}"/>
                        <TextBlock Text="{Binding JoinedAt, StringFormat='Дата вступления: {0:dd.MM.yyyy}'}" Style="{StaticResource LabelBlock}"/>

                        <TextBlock>
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource LabelBlock}">
                                    <Setter Property="Text" Value="Роль: Пользователь"/>
                                    <Setter Property="Foreground" Value="Black"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsModerator}" Value="True">
                                            <Setter Property="Text" Value="Роль: Модератор"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <Separator/>
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>

            <ListView.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Удалить участника" Click="miRemoveMember_Click"/>
                </ContextMenu>
            </ListView.ContextMenu>
        </ListView>
        
    </Grid>
</Page>
