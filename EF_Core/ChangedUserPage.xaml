<Page x:Class="EF_Core.ChangedUserPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:EF_Core"
      xmlns:validators="clr-namespace:EF_Core.Validation"
      mc:Ignorable="d" 
      Background="White"
      d:DesignHeight="650" d:DesignWidth="800"
      Title="ChangedUserPage">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>

        </Grid.RowDefinitions>

        <TextBlock Text="ID:" FontWeight="Bold" Style="{StaticResource LabelBlock}"/>
        <TextBox Grid.Row="1" Text="{Binding Id}" IsReadOnly="True" Style="{StaticResource InputTextBox}"/>

        <TextBlock Grid.Row="2" Text="Номер телефона:" Style="{StaticResource LabelBlock}"/>
        <TextBox Grid.Row="3" Name="NumberPhoneTextBox" Style="{StaticResource InputTextBox}">
            <TextBox.Text>
                <Binding Path="Profile.PhoneNumber" UpdateSourceTrigger="PropertyChanged">
                    <Binding.ValidationRules>
                        <validators:IsEmptyLoginRole/>
                    </Binding.ValidationRules>
                </Binding>
            </TextBox.Text>
        </TextBox>

        <TextBlock Grid.Row="4" Text="Ссылка на аватар:" Style="{StaticResource LabelBlock}"/>
        <TextBox Grid.Row="5" Name="AvatarUrlTextBox" Style="{StaticResource InputTextBox}">
            <TextBox.Text>
                <Binding Path="Profile.AvatarUrl" UpdateSourceTrigger="PropertyChanged" />
            </TextBox.Text>
        </TextBox>

        <TextBlock Grid.Row="6" Text="Дата рождения:" Style="{StaticResource LabelBlock}"/>
        <TextBox Grid.Row="7" Name="BirthDateTextBox" Style="{StaticResource InputTextBox}">
            <TextBox.Text>
                <Binding Path="Profile.BirthDate" 
                         StringFormat="dd.MM.yyyy"
                         UpdateSourceTrigger="PropertyChanged">
                    <Binding.ValidationRules>
                        <validators:IsEmptyRole/>
                        <validators:IsBirthDate/>
                    </Binding.ValidationRules>
                </Binding>
            </TextBox.Text>
        </TextBox>

        <TextBlock Grid.Row="8" Text="Роль:" Style="{StaticResource LabelBlock}"/>
        <ComboBox Grid.Row="9"
              Style="{StaticResource PrimaryComboBox}"
              ItemsSource="{DynamicResource AvailableRoles}"
              DisplayMemberPath="Title"
              SelectedValuePath="Id"
              SelectedValue="{Binding RoleId, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock Grid.Row="10" Text="Биография:" Style="{StaticResource LabelBlock}"/>
        <TextBox Grid.Row="11" Name="BioTextBox" Style="{StaticResource InputTextBox}">
            <TextBox.Text>
                <Binding Path="Profile.Bio" UpdateSourceTrigger="PropertyChanged">
                    <Binding.ValidationRules>
                        <validators:IsEmptyRole/>
                    </Binding.ValidationRules>
                </Binding>
            </TextBox.Text>
        </TextBox>

        <StackPanel Grid.Row="15" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Сохранить" Style="{StaticResource PrimaryButton}" Click="OnSaveClick" Width="100" Margin="5"/>
            <Button Content="Отмена" Style="{StaticResource PrimaryButton}" Click="OnCancelClick" Width="100" Margin="5"/>
        </StackPanel>
    </Grid>
</Page>
